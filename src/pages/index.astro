    <script>
      // Smooth reset animation when home link is clicked on home page
      document.addEventListener('DOMContentLoaded', () => {
        const homeLink = document.querySelector('.home-link');
        const portfolioContent = document.querySelector('.portfolio-content');
        const hero = document.querySelector('.hero');
        
        // Page load animation sequence
        const nav = document.querySelector('.nav');

        // Step 1: Fade in navigation after a short delay
        setTimeout(() => {
          if (nav) nav.classList.remove('initial-hidden');
        }, 500);
        
        // Step 2: Show spheres (they'll pop up via Scene component)
        // Spheres start at 1000ms, with 50 spheres at 20ms intervals
        // Last sphere starts at ~1980ms, finishes at ~2580ms
        
        // Step 3: Fade in hero text after all spheres finish + wait
        setTimeout(() => {
          if (hero) {
            hero.classList.remove('initial-hidden');
            // Trigger slide-in animations
            const maverick = document.querySelector('.name-left');
            const huynh = document.querySelector('.name-right');
            const title = document.querySelector('.title');
            if (maverick) maverick.classList.add('slide-in');
            if (huynh) huynh.classList.add('slide-in');
            // Fade in title text after name slides in
            setTimeout(() => {
              if (title) {
                title.classList.remove('initial-hidden');
                
                // Text cycling animation
                const titleText = title.querySelector('.title-text');
                const texts = ['industrial and systems engineer.', 'founder.', 'designer.'];
                let currentIndex = 0;
                
                // Set initial text
                if (titleText) {
                  titleText.textContent = texts[currentIndex];
                  titleText.style.opacity = '1';
                }
                
                // Cycle through texts
                function cycleText() {
                  if (!titleText) return;
                  
                  // Fade out
                  titleText.style.opacity = '0';
                  
                  setTimeout(() => {
                    // Change text
                    currentIndex = (currentIndex + 1) % texts.length;
                    titleText.textContent = texts[currentIndex];
                    
                    // Fade in
                    setTimeout(() => {
                      titleText.style.opacity = '1';
                    }, 100);
                  }, 1000); // Wait for fade out to complete
                }
                
                // Start cycling after initial display (3 seconds)
                setTimeout(() => {
                  const interval = setInterval(cycleText, 3000); // Change every 3 seconds
                }, 3000);
              }
            }, 800); // After name slide-in completes
          }
        }, 3100); // ~2580ms (spheres finish) + 500ms wait
        
        if (homeLink) {
          homeLink.addEventListener('click', (e) => {
            // If we're already on the home page, trigger smooth reset animation
            if (window.location.pathname === '/') {
              e.preventDefault();
              
              // Scroll to top
              window.scrollTo({
                top: 0,
                behavior: 'smooth'
              });
              
              // Trigger fade-out animation
              if (portfolioContent) {
                portfolioContent.classList.add('fade-out');
              }
              if (hero) {
                hero.classList.add('fade-out');
              }
              
              // After fade-out, fade back in
              setTimeout(() => {
                if (portfolioContent) {
                  portfolioContent.classList.remove('fade-out');
                  portfolioContent.classList.add('fade-in');
                }
                if (hero) {
                  hero.classList.remove('fade-out');
                  hero.classList.add('fade-in');
                }
                
                // Remove fade-in class after animation completes
                setTimeout(() => {
                  if (portfolioContent) {
                    portfolioContent.classList.remove('fade-in');
                  }
                  if (hero) {
                    hero.classList.remove('fade-in');
                  }
                }, 500);
              }, 300);
            }
          });
        }

        // Seamless infinite scroll belt - JavaScript-based for true seamless animation
        const beltContent = document.querySelector('.belt-content');
        if (beltContent) {
          let animationId;
          let position = 0;
          let speed = 0.5; // pixels per frame (adjust for speed)
          
          // Wait for content to render
          setTimeout(() => {
            // Calculate the width of one set (first 4 items)
            const firstSet = beltContent.querySelectorAll('.belt-item');
            let oneSetWidth = 0;
            
            // Get width of first 4 items (one complete set)
            for (let i = 0; i < 4; i++) {
              if (firstSet[i]) {
                const item = firstSet[i];
                const itemWidth = item.offsetWidth;
                const gap = i === 0 ? 0 : 64; // 4rem = 64px
                oneSetWidth += itemWidth + gap;
              }
            }
            
            // Continuous animation function
            function animate() {
              position -= speed;
              
              // When we've scrolled one complete set, reset position imperceptibly
              if (Math.abs(position) >= oneSetWidth) {
                position = 0;
              }
              
              beltContent.style.transform = `translateX(${position}px)`;
              animationId = requestAnimationFrame(animate);
            }
            
            // Start animation
            animate();
            
            // Cleanup on page unload
            window.addEventListener('beforeunload', () => {
              if (animationId) {
                cancelAnimationFrame(animationId);
              }
            });
          }, 100);
        }

        // Email copy functionality
        const emailItems = document.querySelectorAll('.belt-item-email');
        emailItems.forEach(item => {
          item.addEventListener('click', async () => {
            const email = item.getAttribute('data-email');
            const emailText = item.querySelector('.email-text');
            
            try {
              await navigator.clipboard.writeText(email);
              
              // Replace email with "copied!"
              if (emailText) {
                const originalText = emailText.textContent;
                emailText.textContent = 'copied!';
                
                // Restore original text after 2 seconds
                setTimeout(() => {
                  emailText.textContent = originalText;
                }, 2000);
              }
            } catch (err) {
              console.error('Failed to copy email:', err);
            }
          });
        });

        // Video lazy load: only load and play when section is in view
        const videoSection = document.querySelector('.video-section');
        const homeVideo = document.querySelector('.home-video');
        if (videoSection && homeVideo) {
          const videoSrc = homeVideo.getAttribute('data-src');
          if (videoSrc) {
            const videoObserver = new IntersectionObserver(
              (entries) => {
                entries.forEach((entry) => {
                  if (!entry.isIntersecting) return;
                  homeVideo.src = videoSrc;
                  homeVideo.load();
                  homeVideo.play().catch(() => {});
                  videoObserver.unobserve(videoSection);
                });
              },
              { rootMargin: '50px', threshold: 0.1 }
            );
            videoObserver.observe(videoSection);
          }
        }

        // Photo gallery fade-in on scroll
        const photoGallery = document.querySelector('.photo-gallery');
        const galleryText = document.querySelector('.gallery-text');
        
        if (photoGallery && galleryText) {
          // Split text into words and letters, wrap words in spans
          const text = 'Born in Oregon, raised in New Jersey — currently studying ISE and learning how to challenge my own limits.';
          const words = text.split(' ');
          galleryText.innerHTML = words.map((word, wordIndex) => {
            const letters = word.split('');
            const letterSpans = letters.map((char, index) => {
              return `<span class="letter" data-index="${wordIndex}-${index}">${char}</span>`;
            }).join('');
            const wordSpan = `<span class="word">${letterSpans}</span>`;
            // Add space after each word except the last one
            return wordIndex < words.length - 1 ? wordSpan + '<span class="letter space"> </span>' : wordSpan;
          }).join('');
          
          const observerOptions = {
            root: null,
            rootMargin: '0px 0px -10% 0px', // Trigger when section is 10% from bottom of viewport
            threshold: [0, 0.1, 0.2]
          };
          
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                // Fade in text letters one by one
                if (galleryText) {
                  const letters = galleryText.querySelectorAll('.letter');
                  letters.forEach((letter, index) => {
                    setTimeout(() => {
                      letter.classList.add('fade-in');
                    }, index * 25);
                  });
                }
                
                observer.unobserve(entry.target);
              }
            });
          }, observerOptions);
          
          observer.observe(photoGallery);
        }

        // Show floating Mav badge only when photo-gallery section is in view
        const floatingMav = document.querySelector('.floating-mav');
        if (photoGallery && floatingMav) {
          const mavObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                floatingMav.classList.toggle('floating-mav-visible', entry.isIntersecting);
              });
            },
            { threshold: 0.2, rootMargin: '0px' }
          );
          mavObserver.observe(photoGallery);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  html, body {
    margin: 0;
    padding: 0 2.5rem;
    width: 100%;
    min-height: 100vh;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    color: #111;
    background-color: #faf4ef;
    background-image: radial-gradient(circle, rgba(0, 0, 0, 0.08) 2px, transparent 2px);
    background-size: 48px 48px;
    background-attachment: fixed;
    overflow-x: hidden;
    overflow-y: auto;
    box-sizing: border-box;
  }

  /* Section containers – no visible box */
  .section-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 100%;
    margin: 0 2.5rem 2rem 2rem;
    overflow: hidden;
    box-sizing: border-box;
    min-width: 0;
  }

  .portfolio-content {
    position: relative;
    z-index: 10;
    pointer-events: auto;
    transition: opacity 0.3s ease-in-out;
  }

  /* Grid layer only below the hero so hero + spheres stay in front of the grid */
  .portfolio-content::before {
    content: '';
    position: fixed;
    top: 100vh;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, rgba(0, 0, 0, 0.08) 2px, transparent 2px);
    background-size: 48px 48px;
    background-color: transparent;
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .portfolio-content.fade-out {
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }

  .portfolio-content.fade-in {
    opacity: 1;
    animation: fadeIn 0.5s ease-in-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Initial hidden state */
  .initial-hidden {
    opacity: 0;
  }

  /* Navigation fade-in */
  .nav {
    position: fixed;
    top: 1rem;
    left: 2rem;
    right: 2.5rem;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 100;
    transition: opacity 0.6s ease-in;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.5);
    transform: translateZ(0);
    backface-visibility: hidden;
    isolation: isolate;
  }

  .nav:not(.initial-hidden) {
    opacity: 1;
  }

  .nav-text {
    font-size: 0.9rem;
    color: #111;
    letter-spacing: 0.1em;
    line-height: 1.2;
  }

  .home-link {
    color: #111;
    text-decoration: none;
    transition: text-decoration 0.2s, opacity 0.2s;
  }

  .home-link:hover {
    text-decoration: underline;
    opacity: 0.8;
  }

  .menu-icon {
    font-size: 1.5rem;
    cursor: pointer;
  }

  /* Floating Mav badge */
  .floating-mav {
    position: fixed;
    right: 5rem;
